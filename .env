PORT=3000
HOST=0.0.0.0
USERS_FILE=./users.json

# At least one of FIXED_TIMEOUT and SLIDING_TIMEOUT must be set.
# Both set => entry expires at whichever fires first.
# One set  => only that condition applies.
# Format: Nd | Nh | Nm | Ns (e.g. "8h", "30m", "45s").
FIXED_TIMEOUT=8h
SLIDING_TIMEOUT=30m

# How often to walk the allowlist and evict already-expired entries.
# Eviction is otherwise lazy (only on the next /verify for that IP), so
# this bounds memory growth from never-revisited IPs (e.g. dynamic ISP
# leases, NATed clients that disappear).
SWEEP_INTERVAL=24h

# DEV ONLY. When set to "yes", credentialed handlers fall back to
# req.socket.remoteAddress if X-Forwarded-For is missing. Lets you test
# the form via http://localhost:3000 without an Nginx in front. Leave
# unset / "no" in production — behind a real Nginx, X-Forwarded-For is
# always present, so this flag has no effect; but if Nginx is misconfigured
# and forgets the header, you do NOT want to silently allowlist Nginx's
# own address.
TRUST_REMOTE_ADDR=no

DEBUG=no
